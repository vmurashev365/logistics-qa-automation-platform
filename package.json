{
  "name": "logistics-qa-automation-platform",
  "version": "1.0.0",
  "description": "Time-boxed QA automation platform for logistics workflow applications using Playwright, TypeScript, and Cucumber",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "npm run test:smoke",
    "test:smoke": "cucumber-js --config cucumber.js --tags \"@smoke and not @api and not @module_loads\"",
    "test:api": "cucumber-js --config cucumber.js --tags \"@api and not @module_finance and not @module_offline_sync and not @module_cti and not @module_loads\"",
    "test:api:smoke": "cucumber-js --config cucumber.js --tags \"@api-smoke\"",
    "test:web": "cucumber-js --config cucumber.js features/web --tags \"@web\"",
    "test:integration": "cucumber-js --config cucumber.js --tags \"@integration and not @module_finance and not @module_offline_sync and not @module_cti\"",
    "test:security": "cucumber-js --config cucumber.js --tags \"@security\"",
    "test:tablet": "cucumber-js --config cucumber.js features/mobile --tags \"@tablet\"",
    "test:tablet:galaxy": "cucumber-js --config cucumber.js features/mobile --tags \"@galaxy-tab\"",
    "test:tablet:ipad": "cucumber-js --config cucumber.js features/mobile --tags \"@ipad-mini\"",
    "test:tablet:offline": "cucumber-js --config cucumber.js features/mobile --tags \"@tablet and @offline\"",
    "test:accessibility": "cucumber-js --config cucumber.js --tags \"@accessibility\"",
    "test:all": "cucumber-js --config cucumber.js --parallel 2",
    "test:visual": "cucumber-js --config cucumber.js --tags \"@visual\"",
    "test:module:finance": "cucumber-js --config cucumber.js --tags \"@module_finance\"",
    "test:module:offline": "cucumber-js --config cucumber.js --tags \"@module_offline_sync\"",
    "test:module:cti": "cucumber-js --config cucumber.js --tags \"@module_cti\"",
    "test:nightly": "npm run test:smoke && npm run test:api && npm run test:integration",
    "perf:k6:smoke": "k6 run perf/k6/smoke.js",
    "perf:k6:load": "k6 run perf/k6/load.js",
    "report:cucumber": "node scripts/generate-report.js",
    "report:allure": "allure generate allure-results --clean -o allure-report",
    "report:allure:open": "allure open allure-report",
    "allure:history:restore": "node scripts/allure-history.js restore",
    "allure:history:save": "node scripts/allure-history.js save",
    "report:allure:trend": "npm run allure:history:restore && npm run report:allure && npm run allure:history:save",
    "report:allure:trend:open": "npm run report:allure:trend && npm run report:allure:open",
    "db:seed": "ts-node scripts/seed-test-data.ts",
    "db:clean": "ts-node scripts/clean-test-data.ts",
    "docker:start": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"features/**/*.feature\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"features/**/*.feature\"",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "clean": "rimraf dist reports/cucumber/*.json reports/cucumber/*.html"
  },
  "keywords": [
    "qa",
    "automation",
    "playwright",
    "cucumber",
    "bdd",
    "odoo"
  ],
  "author": "Victor Murashev",
  "license": "MIT",
  "dependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "cucumber-html-reporter": "^7.1.1",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "playwright": "^1.48.0",
    "pouchdb-node": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@wdio/allure-reporter": "^8.0.0",
    "allure-commandline": "^2.25.0",
    "allure-cucumberjs": "^3.4.4",
    "eslint": "^9.0.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "pouchdb-adapter-memory": "^9.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  }
}
